{
	"name": "@pobammer-ts/eslint-cease-nonsense-rules",
	"version": "1.38.0",
	"description": "A curated ESLint plugin providing rules to catch common developer missteps and enforce safer coding patterns.",
	"license": "MIT",
	"author": "HowManySmall",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/howmanysmall/eslint-cease-nonsense-rules.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"biome": "biome",
		"biome:ci": "biome ci",
		"biome:lint": "biome lint",
		"build": "tsdown",
		"commitlint": "commitlint",
		"dev": "tsgo -w",
		"docs:build": "nr -F docs build",
		"docs:dev": "nr -F docs dev",
		"format": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run biome -- check --fix $a && node --run oxfmt -- $a' _",
		"format:check": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run biome -- check --no-errors-on-unmatched $a && node --run oxfmt -- --no-error-on-unmatched-pattern --check $a' _",
		"format:safe": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run biome -- check --no-errors-on-unmatched --fix $a && node --run oxfmt -- --no-error-on-unmatched-pattern $a' _",
		"hooks:install": "hk install --mise",
		"hooks:validate": "hk validate",
		"knip": "knip",
		"lint": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run oxlint -- $a && node --run biome -- check $a' _",
		"lint:agent": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run oxlint -- --format agent $a && node --run biome -- check --reporter concise $a' _",
		"oxfmt": "oxfmt",
		"oxlint": "oxlint",
		"prepare": "node --run hooks:install",
		"prepublishOnly": "node --run build -- --minify",
		"release": "bumpp",
		"test": "vitest run --sequence.shuffle",
		"test:agent": "node --run test -- --reporter agent",
		"test:dot": "node --run test -- --reporter dot",
		"test:watch": "vitest --watch",
		"type-check": "node --run typescript -- --noEmit",
		"typescript": "tsgo"
	},
	"dependencies": {
		"arktype": "2.2.1",
		"fast-diff": "1.3.0",
		"oxc-parser": "0.138.0",
		"oxc-resolver": "11.22.0",
		"typebox": "1.3.2"
	},
	"devDependencies": {
		"@antfu/ni": "30.2.0",
		"@babel/core": "7.29.0",
		"@babel/eslint-parser": "7.28.6",
		"@biomejs/biome": "2.5.1",
		"@cliffy/command": "jsr:1.2.1",
		"@commitlint/config-conventional": "21.2.0",
		"@commitlint/types": "21.2.0",
		"@mitata/counters": "0.0.8",
		"@octokit/rest": "22.0.1",
		"@opencode-ai/plugin": "1.17.12",
		"@pobammer-ts/small-rules": "2.3.0",
		"@rbxts/types": "1.0.937",
		"@toon-format/toon": "2.3.0",
		"@total-typescript/ts-reset": "0.6.1",
		"@types/bun": "1.3.14",
		"@types/estree": "1.0.9",
		"@types/node": "22.19.15",
		"@typescript-eslint/parser": "8.62.1",
		"@typescript-eslint/rule-tester": "8.62.1",
		"@typescript-eslint/scope-manager": "8.62.1",
		"@typescript-eslint/types": "8.62.1",
		"@typescript-eslint/utils": "8.62.1",
		"@typescript/native-preview": "7.0.0-dev.20260704.1",
		"@vitest/coverage-v8": "4.1.9",
		"arkenv": "0.12.2",
		"bumpp": "11.1.0",
		"commitlint": "21.2.0",
		"confbox": "0.2.4",
		"consola": "3.4.2",
		"env-paths": "4.0.0",
		"eslint": "10.6.0",
		"eslint-plugin-antfu": "3.2.3",
		"eslint-plugin-regexp": "3.1.1",
		"eslint-plugin-sonarjs": "4.1.0",
		"eslint-plugin-unused-imports": "4.4.1",
		"fast-xml-builder": "1.2.0",
		"get-tsconfig": "4.14.0",
		"jsonc-parser": "3.3.1",
		"just-diff": "6.0.2",
		"knip": "6.23.0",
		"mitata": "1.0.34",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"oxlint-plugin-utilities": "1.1.0",
		"oxlint-tsgolint": "0.24.0",
		"picocolors": "1.1.1",
		"pncat": "0.12.0",
		"pretty-bytes": "7.1.0",
		"pretty-ms": "9.3.0",
		"rotating-file-stream": "3.2.9",
		"skills": "1.5.14",
		"source-map": "0.7.6",
		"sury": "11.0.0-alpha.8",
		"ts-api-utils": "2.5.0",
		"ts-case-convert": "2.3.1",
		"tsdown": "0.22.3",
		"type-fest": "5.7.0",
		"typescript": "^5",
		"valibot": "1.4.2",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.9",
		"vue-eslint-parser": "10.4.1",
		"yup": "1.7.1",
		"zod": "4.4.3",
		"zx": "8.8.5"
	},
	"peerDependencies": {
		"@typescript-eslint/parser": "^8.60.1",
		"@typescript-eslint/utils": "^8.60.1",
		"eslint": "^9.39.4 || ^10.0.0",
		"oxfmt": ">0.19.0"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.1.0",
		"node": ">=20.19"
	},
	"packageManager": "pnpm@11.9.0"
}
