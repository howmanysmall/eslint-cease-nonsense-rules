{
	"name": "@pobammer-ts/eslint-cease-nonsense-rules",
	"version": "1.40.2",
	"description": "A curated ESLint plugin providing rules to catch common developer missteps and enforce safer coding patterns.",
	"license": "MIT",
	"author": "HowManySmall",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/howmanysmall/eslint-cease-nonsense-rules.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"biome": "biome",
		"biome:check:agent": "biome check --reporter concise",
		"biome:ci": "biome ci",
		"biome:lint": "biome lint",
		"build": "tsdown",
		"commitlint": "commitlint",
		"dev": "tsgo -w",
		"docs:build": "nr -F docs build",
		"docs:dev": "nr -F docs dev",
		"format": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run biome -- check --no-errors-on-unmatched $a && node --run oxfmt -- --no-error-on-unmatched-pattern --check $a' _",
		"format:check": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run biome -- check --no-errors-on-unmatched $a && node --run oxfmt -- --no-error-on-unmatched-pattern --check $a' _",
		"format:safe": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run biome -- check --no-errors-on-unmatched --fix $a && node --run oxfmt -- --no-error-on-unmatched-pattern $a' _",
		"hooks:install": "hk install --mise",
		"hooks:validate": "hk validate",
		"knip": "knip",
		"lint": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run oxlint -- $a && node --run biome -- check $a' _",
		"lint:agent": "bash -c 'a=$(bash scripts/get-defaults.sh \"$@\"); node --run oxlint -- --format agent $a && node --run biome -- check --reporter concise $a' _",
		"oxfmt": "oxfmt",
		"oxlint": "oxlint",
		"oxlint:agent": "oxlint --format agent",
		"pncat": "pncat",
		"prepare": "node --run hooks:install",
		"prepublishOnly": "node --run build -- --minify",
		"release": "bumpp",
		"test": "vitest run --sequence.shuffle",
		"test:agent": "node --run test -- --reporter agent",
		"test:dot": "node --run test -- --reporter dot",
		"test:watch": "vitest --watch",
		"type-check": "node --run typescript -- --noEmit",
		"type-check:agent": "node --run typescript -- --noEmit --pretty false",
		"typescript": "tsgo"
	},
	"dependencies": {
		"@typescript-eslint/scope-manager": "catalog:lint",
		"arktype": "catalog:prod",
		"fast-diff": "catalog:prod",
		"oxc-parser": "catalog:prod",
		"oxc-resolver": "catalog:prod",
		"typebox": "catalog:prod"
	},
	"devDependencies": {
		"@antfu/ni": "catalog:dev",
		"@babel/core": "catalog:dev",
		"@babel/eslint-parser": "catalog:lint",
		"@biomejs/biome": "catalog:lint",
		"@cliffy/command": "catalog:dev",
		"@commitlint/config-conventional": "catalog:dev",
		"@commitlint/types": "catalog:dev",
		"@mitata/counters": "catalog:dev",
		"@octokit/rest": "catalog:dev",
		"@opencode-ai/plugin": "catalog:dev",
		"@pobammer-ts/small-rules": "catalog:dev",
		"@rbxts/types": "catalog:dev",
		"@toon-format/toon": "catalog:dev",
		"@total-typescript/ts-reset": "catalog:dev",
		"@types/bun": "catalog:types",
		"@types/estree": "catalog:types",
		"@types/node": "catalog:types",
		"@typescript-eslint/parser": "catalog:lint",
		"@typescript-eslint/rule-tester": "catalog:lint",
		"@typescript-eslint/types": "catalog:lint",
		"@typescript-eslint/utils": "catalog:lint",
		"@typescript/native-preview": "catalog:dev",
		"@vitest/coverage-v8": "catalog:test",
		"arkenv": "catalog:dev",
		"bumpp": "catalog:dev",
		"commitlint": "catalog:dev",
		"confbox": "catalog:dev",
		"consola": "catalog:dev",
		"env-paths": "catalog:dev",
		"eslint": "catalog:lint",
		"eslint-plugin-antfu": "catalog:lint",
		"eslint-plugin-regexp": "catalog:lint",
		"eslint-plugin-sonarjs": "catalog:lint",
		"eslint-plugin-unused-imports": "catalog:lint",
		"fast-xml-builder": "catalog:dev",
		"jsonc-parser": "catalog:dev",
		"just-diff": "catalog:dev",
		"knip": "catalog:lint",
		"mitata": "catalog:dev",
		"oxfmt": "catalog:dev",
		"oxlint": "catalog:dev",
		"oxlint-tsgolint": "catalog:dev",
		"picocolors": "catalog:dev",
		"pncat": "catalog:dev",
		"pretty-bytes": "catalog:dev",
		"pretty-ms": "catalog:dev",
		"rotating-file-stream": "catalog:dev",
		"skills": "catalog:dev",
		"source-map": "catalog:dev",
		"ts-api-utils": "catalog:dev",
		"ts-case-convert": "catalog:dev",
		"tsdown": "catalog:build",
		"type-fest": "catalog:dev",
		"typescript": "catalog:dev",
		"vitest": "catalog:test",
		"vue-eslint-parser": "catalog:lint"
	},
	"peerDependencies": {
		"@typescript-eslint/parser": "catalog:lint",
		"@typescript-eslint/utils": "catalog:lint",
		"eslint": "^9.39.4 || ^10.0.0",
		"oxfmt": ">0.19.0"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.1.0",
		"node": ">=20.19"
	},
	"packageManager": "pnpm@11.9.0"
}
