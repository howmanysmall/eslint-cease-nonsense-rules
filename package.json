{
	"name": "@pobammer-ts/eslint-cease-nonsense-rules",
	"version": "1.34.0",
	"description": "A curated ESLint plugin providing rules to catch common developer missteps and enforce safer coding patterns.",
	"license": "MIT",
	"author": "HowManySmall",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/howmanysmall/eslint-cease-nonsense-rules.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"biome": "biome",
		"biome:check": "biome check",
		"biome:ci": "biome ci",
		"biome:lint": "biome lint",
		"build": "bun run --bun ./scripts/build.ts",
		"build:oxc": "bun run --bun ./scripts/build-small-rules.ts",
		"commitlint": "commitlint",
		"dev": "tsgo -w",
		"docs:build": "aube run -F docs build",
		"docs:dev": "aube run -F docs dev",
		"format": "oxfmt",
		"knip": "knip",
		"lint": "bash -c 'a=$(bash scripts/default-src.sh \"$@\"); aube run oxc $a && aube run biome check $a' _",
		"oxc": "oxlint",
		"prepare": "hk install",
		"prepublishOnly": "aube run build",
		"release": "bumpp",
		"release:undo": "bash ./scripts/release-undo.sh",
		"test": "vitest run --sequence.shuffle",
		"test:agent": "vitest run --reporter agent --sequence.shuffle",
		"test:watch": "vitest --watch",
		"type-check": "tsgo --noEmit",
		"typescript": "tsgo"
	},
	"dependencies": {
		"arktype": "^2.2.0",
		"fast-diff": "^1.3.0",
		"oxc-parser": "^0.129.0",
		"oxc-resolver": "^11.19.1",
		"typebox": "^1.1.38"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/eslint-parser": "^7.28.6",
		"@biomejs/biome": "^2.4.15",
		"@cliffy/command": "jsr:^1.1.0",
		"@commitlint/config-conventional": "^21.0.0",
		"@commitlint/types": "^21.0.0",
		"@mitata/counters": "^0.0.8",
		"@octokit/rest": "^22.0.1",
		"@opencode-ai/plugin": "^1.14.46",
		"@rbxts/types": "^1.0.919",
		"@toon-format/toon": "^2.2.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/bun": "^1.3.13",
		"@types/estree": "^1.0.8",
		"@types/node": "^22.19.15",
		"@typescript-eslint/parser": "^8.59.2",
		"@typescript-eslint/rule-tester": "^8.59.2",
		"@typescript-eslint/scope-manager": "^8.59.2",
		"@typescript-eslint/types": "^8.59.2",
		"@typescript-eslint/utils": "^8.59.2",
		"@typescript/native-preview": "7.0.0-dev.20260509.2",
		"@vitest/coverage-v8": "4.1.5",
		"arkenv": "^0.11.0",
		"bumpp": "^11.1.0",
		"commitlint": "^21.0.0",
		"confbox": "^0.2.4",
		"consola": "^3.4.2",
		"env-paths": "^4.0.0",
		"eslint": "^9.39.4",
		"fast-xml-builder": "^1.2.0",
		"jsonc-parser": "^3.3.1",
		"just-diff": "^6.0.2",
		"knip": "^6.12.2",
		"mitata": "^1.0.34",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.63.0",
		"oxlint-plugin-utilities": "^1.0.0",
		"oxlint-tsgolint": "^0.22.1",
		"picocolors": "^1.1.1",
		"pretty-bytes": "^7.1.0",
		"pretty-ms": "^9.3.0",
		"rotating-file-stream": "^3.2.9",
		"skills": "^1.5.6",
		"source-map": "^0.7.6",
		"sury": "^11.0.0-alpha.4",
		"ts-api-utils": "^2.5.0",
		"ts-case-convert": "^2.1.0",
		"tsdown": "^0.22.0",
		"type-fest": "^5.6.0",
		"typescript": "^5",
		"valibot": "^1.4.0",
		"vitest": "4.1.5",
		"vue-eslint-parser": "^10.4.0",
		"yup": "^1.7.1",
		"zod": "^4.4.3",
		"zx": "^8.8.5"
	},
	"peerDependencies": {
		"@typescript-eslint/parser": "^8.59.2",
		"@typescript-eslint/utils": "^8.59.2",
		"eslint": "^9.39.4",
		"oxfmt": ">0.19.0"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.1.0",
		"node": ">=20.18"
	},
	"packageManager": "aube@1.9.1"
}
