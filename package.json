{
	"name": "@pobammer-ts/eslint-cease-nonsense-rules",
	"version": "1.34.0",
	"description": "A curated ESLint plugin providing rules to catch common developer missteps and enforce safer coding patterns.",
	"license": "MIT",
	"author": "HowManySmall",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/howmanysmall/eslint-cease-nonsense-rules.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./dist/index.d.ts"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"add-tsgolint": "bun add -D oxlint-tsgolint@latest",
		"biome:check": "biome check",
		"biome:ci": "biome ci",
		"biome:lint": "biome lint",
		"build": "./scripts/build.ts",
		"build:legacy": "tsgo -p tsconfig.json",
		"commitlint": "commitlint --edit",
		"dev": "tsgo -w",
		"docs:build": "bun --cwd documentation build",
		"docs:dev": "bun --cwd documentation dev",
		"format": "oxfmt",
		"knip": "knip-bun",
		"lint": "bash -c 'a=$(bash scripts/default-src.sh \"$@\"); bun run oxc $a && bun run biome:check $a' _",
		"lint:fix": "bun run oxc . --fix && bun run biome:check . --fix",
		"oxc": "oxlint",
		"prepare": "lefthook install",
		"prepublishOnly": "bun run build",
		"release": "bumpp",
		"test": "bun test --randomize",
		"test:watch": "bun run test --watch",
		"type-check": "tsgo --noEmit",
		"type-check:safe": "tsc --noEmit"
	},
	"dependencies": {
		"arktype": "^2.2.0",
		"fast-diff": "^1.3.0",
		"oxc-parser": "^0.123.0",
		"oxc-resolver": "^11.19.1",
		"typebox": "^1.1.14"
	},
	"devDependencies": {
		"@babel/core": "^7.29.0",
		"@babel/eslint-parser": "^7.28.6",
		"@biomejs/biome": "^2.4.10",
		"@commitlint/config-conventional": "^20.5.0",
		"@commitlint/types": "^20.5.0",
		"@jsr/cliffy__command": "^1.0.0",
		"@mitata/counters": "^0.0.8",
		"@octokit/rest": "^22.0.1",
		"@opencode-ai/plugin": "^1.3.13",
		"@rbxts/types": "^1.0.913",
		"@toon-format/toon": "^2.1.0",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/bun": "1.3.11",
		"@types/estree": "^1.0.8",
		"@types/node": "^22.19.15",
		"@typescript-eslint/parser": "^8.58.0",
		"@typescript-eslint/rule-tester": "^8.58.0",
		"@typescript-eslint/scope-manager": "^8.58.0",
		"@typescript-eslint/types": "^8.58.0",
		"@typescript-eslint/utils": "^8.58.0",
		"@typescript/native-preview": "7.0.0-dev.20260404.1",
		"arkenv": "^0.11.0",
		"better-result": "^2.7.0",
		"bumpp": "^11.0.1",
		"commitlint": "^20.5.0",
		"confbox": "^0.2.4",
		"consola": "^3.4.2",
		"env-paths": "^4.0.0",
		"eslint": "^9.39.4",
		"fast-xml-parser": "^5.5.9",
		"jsonc-parser": "^3.3.1",
		"just-diff": "^6.0.2",
		"knip": "^6.2.0",
		"mitata": "^1.0.34",
		"oxfmt": "^0.43.0",
		"oxlint": "^1.58.0",
		"oxlint-tsgolint": "^0.19.0",
		"picocolors": "^1.1.1",
		"pretty-bytes": "^7.1.0",
		"pretty-ms": "^9.3.0",
		"rotating-file-stream": "^3.2.9",
		"source-map": "^0.7.6",
		"sury": "^11.0.0-alpha.4",
		"temporal-polyfill": "^0.3.2",
		"ts-api-utils": "^2.5.0",
		"ts-case-convert": "^2.1.0",
		"type-fest": "^5.5.0",
		"typescript": "^5",
		"valibot": "^1.3.1",
		"vue-eslint-parser": "^10.4.0",
		"yup": "^1.7.1",
		"zod": "^4.3.6"
	},
	"peerDependencies": {
		"@typescript-eslint/parser": "^8.58.0",
		"@typescript-eslint/utils": "^8.58.0",
		"eslint": "^9.39.4",
		"oxfmt": ">0.19.0"
	},
	"peerDependenciesMeta": {
		"oxfmt": {
			"optional": true
		},
		"typescript": {
			"optional": true
		}
	},
	"engines": {
		"bun": ">=1.1.0",
		"node": ">=20.18"
	},
	"packageManager": "bun@1.3.11"
}
