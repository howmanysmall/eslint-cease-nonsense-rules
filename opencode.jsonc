{
	"$schema": "https://opencode.ai/config.json",
	"agent": {
		"ask": {
			"color": "#7C3AED",
			"description": "General Q&A - ask questions about code, concepts, debugging strategies without executing anything",
			"disable": false,
			"mode": "all",
			"model": "openai/gpt-5.4",
			"permission": {
				"bash": {
					"*": "ask",
					"bat*": "allow",
					"cat*": "allow",
					"cd*": "allow",
					"delta*": "allow",
					"diff*": "allow",
					"du*": "allow",
					"dust*": "allow",
					"exa*": "allow",
					"fd*": "allow",
					"find*": "allow",
					"git diff*": "allow",
					"git status*": "allow",
					"grep*": "allow",
					"ls*": "allow",
					"lsd*": "allow",
					"rg*": "allow",
					"sd*": "allow",
					"sed*": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "deny",
				"edit": "deny",
				"external_directory": "deny",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "ask",
				"read": "allow",
				"task": "deny",
				"todoread": "allow",
				"todowrite": "deny",
				"webfetch": "allow",
				"websearch": "allow",
			},
			"prompt": "{file:./prompts/agents/ask.md}",
			"temperature": 0.3,
		},
		"build": {
			"description": "Used after creating a plan or just whenever.",
			"mode": "all",
			"model": "openai/gpt-5.4",
			"permission": {
				"bash": {
					"*": "ask",
					"aube run biome:check*": "allow",
					"aube run biome:ci*": "allow",
					"aube run biome:lint*": "allow",
					"aube run build*": "allow",
					"aube run dev*": "allow",
					"aube run format*": "allow",
					"aube run knip*": "allow",
					"aube run lint*": "allow",
					"aube run oxc:complete*": "allow",
					"aube run oxc:raw*": "allow",
					"aube run oxc*": "allow",
					"aube run test*": "allow",
					"aube run type-check": "allow",
					"bat*": "allow",
					"cat*": "allow",
					"date*": "allow",
					"delta*": "allow",
					"diff*": "allow",
					"du*": "allow",
					"dust*": "allow",
					"echo*": "allow",
					"exa*": "allow",
					"fd*": "allow",
					"find*": "allow",
					"git diff*": "allow",
					"git status*": "allow",
					"grep*": "allow",
					"head*": "allow",
					"ls*": "allow",
					"lsd*": "allow",
					"mkdir*": "allow",
					"pwd*": "allow",
					"rg*": "allow",
					"sd*": "allow",
					"sed*": "allow",
					"sort*": "allow",
					"tail*": "allow",
					"tree*": "allow",
					"wc*": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "ask",
				"edit": "allow",
				"external_directory": "ask",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"skill": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "ask",
				"websearch": "allow",
			},
		},
		"build-glm": {
			"description": "Used to generate a plan.",
			"model": "zai-coding-plan/glm-5.1",
			"permission": {
				"bash": {
					"*": "ask",
					"aube run test*": "allow",
					"bat*": "allow",
					"cat*": "allow",
					"cd*": "allow",
					"delta*": "allow",
					"diff*": "allow",
					"du*": "allow",
					"dust*": "allow",
					"exa*": "allow",
					"fd*": "allow",
					"find*": "allow",
					"grep*": "allow",
					"ls*": "allow",
					"lsd*": "allow",
					"rg*": "allow",
					"sd*": "allow",
					"sed*": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "ask",
				"edit": "deny",
				"external_directory": "ask",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"skill": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "ask",
				"websearch": "allow",
			},
		},
		"build-kimi": {
			"description": "Used to generate a plan.",
			"model": "kimi-for-coding/k2p6",
			"permission": {
				"bash": {
					"*": "ask",
					"aube run test*": "allow",
					"bat*": "allow",
					"cat*": "allow",
					"cd*": "allow",
					"delta*": "allow",
					"diff*": "allow",
					"du*": "allow",
					"dust*": "allow",
					"exa*": "allow",
					"fd*": "allow",
					"find*": "allow",
					"grep*": "allow",
					"ls*": "allow",
					"lsd*": "allow",
					"rg*": "allow",
					"sd*": "allow",
					"sed*": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "ask",
				"edit": "deny",
				"external_directory": "ask",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"skill": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "ask",
				"websearch": "allow",
			},
		},
		"plan": {
			"description": "Used to generate a plan.",
			"model": "openai/gpt-5.4",
			"permission": {
				"bash": {
					"*": "ask",
					"bat*": "allow",
					"cat*": "allow",
					"cd*": "allow",
					"delta*": "allow",
					"diff*": "allow",
					"du*": "allow",
					"dust*": "allow",
					"exa*": "allow",
					"fd*": "allow",
					"find*": "allow",
					"git diff*": "allow",
					"git status*": "allow",
					"grep*": "allow",
					"ls*": "allow",
					"lsd*": "allow",
					"rg*": "allow",
					"sd*": "allow",
					"sed*": "allow",
				},
				"codesearch": "allow",
				"doom_loop": "ask",
				"edit": "deny",
				"external_directory": "ask",
				"glob": "allow",
				"grep": "allow",
				"list": "allow",
				"lsp": "allow",
				"question": "allow",
				"read": "allow",
				"skill": "allow",
				"task": "allow",
				"todoread": "allow",
				"todowrite": "allow",
				"webfetch": "ask",
				"websearch": "allow",
			},
			"prompt": "{file:./prompts/agents/plan.md}",
		},
	},
	"experimental": {
		"batch_tool": true,
	},
	"formatter": {
		"biome": {
			"command": ["aube", "run", "biome", "format", "--", "--write", "$FILE"],
			"disabled": false,
			"extensions": [
				".astro",
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".html",
				".js",
				".json",
				".jsonc",
				".jsx",
				".mjs",
				".mts",
				".scss",
				".svelte",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"oxfmt": {
			"command": ["aube", "run", "format", "$FILE"],
			"disabled": false,
			"environment": {},
			"extensions": [
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".handlebars",
				".hbs",
				".htm",
				".html",
				".js",
				".json",
				".json5",
				".jsonc",
				".jsx",
				".less",
				".mdx",
				".mjs",
				".mts",
				".sass",
				".scss",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"rumdl": {
			"command": ["rumdl", "check", "--fix", "$FILE"],
			"disabled": false,
			"extensions": [
				".md",
				".markdown",
				".mdown",
				".mkdn",
				".mkd",
				".mdwn",
				".mdtxt",
				".mdtext",
				".text",
				".Rmd",
			],
		},
		"tombi": {
			"command": ["tombi", "format", "$FILE"],
			"disabled": false,
			"extensions": [".toml"],
		},
	},
	"instructions": ["./AGENTS.md"],
	"layout": "stretch",
	"lsp": {
		"biome": {
			"command": ["aube", "run", "biome", "lsp-proxy"],
			"disabled": false,
			"env": {},
			"extensions": [
				".astro",
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".html",
				".js",
				".json",
				".jsonc",
				".jsx",
				".mjs",
				".mts",
				".scss",
				".svelte",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
		},
		"eslint": { "disabled": true },
		"oxfmt": {
			"command": ["aube", "run", "format", "--", "--lsp"],
			"disabled": false,
			"env": {},
			"extensions": [
				".cjs",
				".css",
				".cts",
				".gql",
				".graphql",
				".handlebars",
				".hbs",
				".htm",
				".html",
				".js",
				".json",
				".json5",
				".jsonc",
				".jsx",
				".less",
				".mdx",
				".mjs",
				".mts",
				".sass",
				".scss",
				".ts",
				".tsx",
				".vue",
				".yaml",
				".yml",
			],
			"initialization": {},
		},
		"oxlint": {
			"command": ["aube", "run", "oxc", "--", "--lsp"],
			"disabled": false,
			"env": {},
			"extensions": [".js", ".mjs", ".cjs", ".ts", ".mts", ".cts", ".jsx", ".tsx", ".vue", ".svelte", ".astro"],
			"initialization": {},
		},
		"rumdl": {
			"command": ["rumdl", "server"],
			"disabled": false,
			"extensions": [
				".md",
				".markdown",
				".mdown",
				".mkdn",
				".mkd",
				".mdwn",
				".mdtxt",
				".mdtext",
				".text",
				".Rmd",
			],
		},
		"tombi": {
			"command": ["tombi", "lsp"],
			"disabled": false,
			"extensions": [".toml"],
		},
		"typescript": {
			"command": ["aube", "run", "typescript", "--", "--lsp", "--stdio"],
			"disabled": false,
			"extensions": [".ts", ".tsx"],
		},
	},
	"mcp": {
		"astro-docs": {
			"type": "remote",
			"url": "https://mcp.docs.astro.build/mcp",
		},
		"chrome-dev-tools": {
			"command": ["bash", "./scripts/get-chrome-path.sh", "--serve"],
			"enabled": true,
			"type": "local",
		},
		"context7": {
			"enabled": true,
			"headers": { "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}" },
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
		},
		"gh-grep": {
			"enabled": true,
			"type": "remote",
			"url": "https://mcp.grep.app",
		},
		"minimax": {
			"command": ["uvx", "minimax-coding-plan-mcp", "-y"],
			"enabled": true,
			"environment": {
				"MINIMAX_API_HOST": "https://api.minimax.io",
				"MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
			},
			"type": "local",
		},
		"npm-registry": {
			"command": ["npm-registry-mcp"],
			"enabled": true,
			"type": "local",
		},
	},
	"permission": {
		"bash": {
			"*": "ask",
			"bat*": "allow",
			"cat*": "allow",
			"cd*": "allow",
			"delta*": "allow",
			"diff*": "allow",
			"du*": "allow",
			"dust*": "allow",
			"exa*": "allow",
			"fd*": "allow",
			"find*": "allow",
			"grep*": "allow",
			"ls*": "allow",
			"lsd*": "allow",
			"rg*": "allow",
			"sd*": "allow",
			"sed*": "allow",
		},
		"codesearch": "allow",
		"doom_loop": "ask",
		"edit": "ask",
		"external_directory": "ask",
		"skill": "allow",
		"webfetch": "ask",
		"websearch": "allow",
	},
	"plugin": ["opencode-wakatime"],
	"provider": {
		"openai": {
			"models": {
				"gpt-5.4": {
					"limit": { "context": 200000, "output": 128000 },
				},
				"gpt-5.5": {
					"limit": { "context": 400000, "output": 128000 },
				},
			},
		},
	},
	"username": "small-eslint",
}
