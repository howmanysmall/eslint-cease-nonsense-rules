amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"

local sourceGlobs = List("*.js", "*.jsx", "*.ts", "*.tsx")
local dataGlobs = List("*.css", "*.html", "*.json", "*.jsonc", "*.grit", "*.code-workspace")

hooks {
  ["commit-msg"] {
    steps {
      ["commitlint"] {
        check = "node --run commitlint -- --edit {{ hook_args }}"
      }
    }
  }
  ["post-merge"] {
    steps {
      ["install"] {
        check = "ni"
      }
    }
  }
  ["pre-commit"] {
    fix = true
    stage = true
    stash = "git"
    steps {
      ["biome-data"] {
        glob = dataGlobs
        fix = "node --run biome -- check --write --no-errors-on-unmatched {{ files }}"
      }
      ["js-ts-fix"] {
        glob = sourceGlobs
        fix =
          "node --run oxlint -- --fix {{ files }} && node --run biome -- check --write --no-errors-on-unmatched {{ files }} && node --run format -- {{ files }}"
      }
      ["format-json5-mdx"] {
        glob = List("*.json5", "*.mdx")
        fix = "node --run format -- {{ files }}"
      }
      ["md-fix"] {
        glob = List("*.md")
        fix = "rumdl check --fix {{ files }} && rumdl fmt {{ files }}"
      }
      ["toml-fix"] {
        glob = List("*.toml")
        fix = "tombi lint {{ files }} && tombi format {{ files }}"
      }
    }
  }
  ["pre-push"] {
    steps {
      ["biome-ci"] {
        check = "node --run biome -- ci"
      }
      ["oxlint"] {
        check = "node --run oxlint"
      }
      ["type-check"] {
        check = "node --run type-check"
      }
      ["knip"] {
        check = "node --run knip"
      }
      ["build"] {
        check = "node --run build"
      }
      ["test-documentation"] {
        check = "AGENT=1 node --run test -- tests/documentation/rule-stats.test.ts"
      }
    }
  }
}
