{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"assist": {
		"enabled": true,
		"includes": ["**", "!**/*.js", "!**/*-lock.{json,yaml}"],
		"actions": {
			"source": {
				"noDuplicateClasses": "on",
				"organizeImports": "off",
				"preset": "recommended",
				"useSortedAttributes": "on",
				"useSortedEnumMembers": "on",
				"useSortedInterfaceMembers": "on",
				"useSortedPackageJson": "off",
				"useSortedProperties": "on",
				"useSortedSelectionSet": "on",
				"useSortedTypeFields": "on",
				"useSortedKeys": {
					"level": "on",
					"options": {
						"groupByNesting": false,
						"sortOrder": "lexicographic"
					}
				}
			}
		}
	},

	"css": {
		"assist": { "enabled": true },
		"globals": [],
		"linter": { "enabled": true },
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"indentWidth": 4,
			"lineWidth": 120,
			"quoteStyle": "double"
		}
	},

	"files": {
		"includes": ["**", "!**/package.json", "!**/*.js", "!**/*-lock.{json,yaml}"]
	},

	"formatter": {
		"attributePosition": "auto",
		"bracketSameLine": false,
		"bracketSpacing": true,
		"enabled": true,
		"expand": "auto",
		"formatWithErrors": true,
		"includes": ["**", "!**/*.js", "!**/{dist,do-not-sync-ever,garbage,node_modules}/**"],
		"indentStyle": "tab",
		"indentWidth": 4,
		"lineEnding": "lf",
		"lineWidth": 120,
		"useEditorconfig": false
	},

	"graphql": {
		"assist": { "enabled": true },
		"linter": { "enabled": true },
		"formatter": {
			"bracketSpacing": true,
			"enabled": true,
			"indentStyle": "tab",
			"indentWidth": 4,
			"lineWidth": 120,
			"quoteStyle": "double"
		}
	},

	"grit": {
		"assist": { "enabled": true },
		"linter": { "enabled": true },
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"indentWidth": 4,
			"lineWidth": 120
		}
	},

	"html": {
		"assist": { "enabled": true },
		"experimentalFullSupportEnabled": true,
		"linter": { "enabled": true },
		"formatter": {
			"attributePosition": "auto",
			"bracketSameLine": true,
			"enabled": true,
			"indentScriptAndStyle": true,
			"indentStyle": "tab",
			"indentWidth": 4,
			"lineEnding": "lf",
			"lineWidth": 120,
			"selfCloseVoidElements": "always",
			"whitespaceSensitivity": "strict"
		},
		"parser": {
			"interpolation": true,
			"vue": false
		}
	},

	"javascript": {
		"globals": ["Bun"],
		"linter": { "enabled": true },
		"formatter": {
			"arrowParentheses": "always",
			"attributePosition": "auto",
			"bracketSameLine": false,
			"bracketSpacing": true,
			"enabled": true,
			"expand": "auto",
			"indentStyle": "tab",
			"indentWidth": 4,
			"jsxQuoteStyle": "double",
			"lineEnding": "lf",
			"lineWidth": 120,
			"quoteProperties": "asNeeded",
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},

	"json": {
		"assist": { "enabled": true },
		"linter": { "enabled": true },
		"parser": {},
		"formatter": {
			"bracketSpacing": true,
			"enabled": true,
			"expand": "auto",
			"indentStyle": "tab",
			"indentWidth": 4,
			"lineWidth": 120,
			"trailingCommas": "none"
		}
	},

	"linter": {
		"enabled": true,
		"includes": ["**", "!**/{dist,do-not-sync-ever,garbage,node_modules}/**"],
		"rules": {
			"a11y": { "preset": "none" },

			"complexity": {
				"noDivRegex": "error",
				"noExcessiveNestedTestSuites": "error",
				"noForEach": "error",
				"noImplicitCoercions": "error",
				"noRedundantDefaultExport": "error",
				"noUselessCatchBinding": "error",
				"noUselessReturn": "error",
				"noUselessStringConcat": "error",
				"noUselessSwitchCase": "off",
				"preset": "none",
				"useArrayFind": "error",
				"useArrowFunction": "off",
				"useDateNow": "error",
				"useFlatMap": "error",
				"useLiteralKeys": "error",
				"useOptionalChain": "error",
				"useSimpleNumberKeys": "error",
				"useSimplifiedLogicExpression": "error",
				"useWhile": "error",
				"useMaxParams": {
					"level": "error",
					"options": { "max": 7 }
				}
			},

			"correctness": {
				"noGlobalDirnameFilename": "error",
				"noNodejsModules": "off",
				"noUnresolvedImports": "off",
				"noUnusedImports": "error",
				"noUnusedInstantiation": "error",
				"noUnusedPrivateClassMembers": "error",
				"noUnusedVariables": "error",
				"preset": "recommended",
				"useInlineScriptId": "error",
				"useJsonImportAttributes": "off",
				"useSingleJsDocAsterisk": "error",
				"noUndeclaredDependencies": {
					"level": "error",
					"options": {}
				},
				"noUndeclaredVariables": {
					"level": "error",
					"options": { "checkTypes": true }
				}
			},

			"nursery": {
				"noBaseToString": "error",
				"noConditionalExpect": "error",
				"noFloatingPromises": "error",
				"noIdenticalTestTitle": "error",
				"noImpliedEval": "error",
				"noLoopFunc": "error",
				"noMisleadingReturnType": "off",
				"noMisusedPromises": "error",
				"noUnsafePlusOperands": "error",
				"noUselessTypeConversion": "off",
				"preset": "recommended",
				"useArraySome": "error",
				"useAwaitThenable": "error",
				"useConsistentTestIt": "error",
				"useDisposables": "error",
				"useDomNodeTextContent": "error",
				"useDomQuerySelector": "error",
				"useExhaustiveSwitchCases": "error",
				"useExpect": "error",
				"useExplicitReturnType": "error",
				"useExplicitType": "off",
				"useIframeSandbox": "error",
				"useImportsFirst": "error",
				"useMathMinMax": "error",
				"useNamedCaptureGroup": "error",
				"useNullishCoalescing": "error",
				"useReduceTypeParameter": "error",
				"useRegexpExec": "error",
				"useRegexpTest": "error",
				"useSortedClasses": "error",
				"useStringStartsEndsWith": "error",
				"useTestHooksInOrder": "error",
				"useTestHooksOnTop": "error",
				"useThisInClassMethods": "error",
				"useUnicodeRegex": "error",
				"useVarsOnTop": "error",
				"noExcessiveNestedCallbacks": {
					// temporarily disabled
					"level": "off",
					"options": { "max": 5 }
				}
			},

			"performance": {
				"noAccumulatingSpread": "error",
				"noAwaitInLoops": "off",
				"noDelete": "error",
				"noSyncScripts": "error",
				"preset": "recommended",
				"useSolidForComponent": "error",
				"useTopLevelRegex": "error"
			},

			"security": {
				"noDangerouslySetInnerHtml": "off",
				"noScriptUrl": "error",
				"preset": "recommended"
			},

			"style": {
				"noCommonJs": "error",
				"noDefaultExport": "off",
				"noDescendingSpecificity": "error",
				"noDoneCallback": "error",
				"noEnum": "off",
				"noExportedImports": "error",
				"noHeadElement": "error",
				"noImplicitBoolean": "error",
				"noInferrableTypes": "error",
				"noJsxLiterals": "error",
				"noMagicNumbers": "off",
				"noMultiAssign": "error",
				"noMultilineString": "error",
				"noNamespace": "error",
				"noNegationElse": "error",
				"noNestedTernary": "error",
				"noNonNullAssertion": "off",
				"noParameterAssign": "error",
				"noParameterProperties": "error",
				"noProcessEnv": "error",
				"noRestrictedGlobals": "error",
				"noRestrictedImports": "error",
				"preset": "recommended",
				"useArrayLiterals": "off",
				"useBlockStatements": "off",
				"useConsistentEnumValueType": "error",
				"useConsistentMemberAccessibility": "off",
				"useConsistentMethodSignatures": "off",
				"useDefaultParameterLast": "error",
				"useDestructuring": "off",
				"useErrorCause": "error",
				"useGlobalThis": "error",
				"useSpreadOverApply": "error",
				"noExcessiveClassesPerFile": {
					"level": "error",
					"options": { "maxClasses": 3 }
				},
				"noExcessiveLinesPerFile": {
					"level": "off",
					"options": {
						"maxLines": 200,
						"skipBlankLines": true
					}
				},
				"noRestrictedTypes": {
					"level": "error",
					"options": {
						"types": {
							"Omit": {
								"message": "Use Except from type-fest instead.",
								"use": "Except"
							}
						}
					}
				},
				"useConst": {
					"fix": "safe",
					"level": "error"
				},
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"filenameCases": ["kebab-case"],
						"requireAscii": true
					}
				}
			},

			"suspicious": {
				"noAlert": "error",
				"noApproximativeNumericConstant": "error",
				"noArrayIndexKey": "error",
				"noConstEnum": "off",
				"noControlCharactersInRegex": "off",
				"noDuplicateEnumValues": "error",
				"noEmptyBlockStatements": "error",
				"noEqualsToNull": "error",
				"noForIn": "error",
				"noNestedPromises": "error",
				"noParametersOnlyUsedInRecursion": "error",
				"noProto": "error",
				"noReturnAssign": "error",
				"noTemplateCurlyInString": "off",
				"noUndeclaredEnvVars": "error",
				"noUnnecessaryConditions": "off",
				"preset": "recommended",
				"useArraySortCompare": "error",
				"noShadow": {
					"level": "off",
					"options": {
						"ignoreFunctionTypeParameterNameValueShadow": false,
						"ignoreTypeValueShadow": false
					}
				}
			}
		}
	},

	"overrides": [
		// JSONC Files
		{
			"includes": ["**/*.jsonc", "!**/biome.jsonc"],
			"json": {
				"linter": { "enabled": true },
				"formatter": {
					"enabled": true,
					"indentStyle": "tab",
					"indentWidth": 4,
					"lineWidth": 120,
					"trailingCommas": "all"
				},
				"parser": {
					"allowComments": true,
					"allowTrailingCommas": true
				}
			}
		},

		// JSON Files
		{
			"includes": [],
			"json": {
				"linter": { "enabled": true },
				"formatter": {
					"enabled": true,
					"indentStyle": "tab",
					"indentWidth": 4,
					"lineWidth": 120,
					"trailingCommas": "none"
				},
				"parser": {
					"allowComments": false,
					"allowTrailingCommas": false
				}
			}
		},

		{
			"includes": ["tests/**/*.test.ts"],
			"linter": {
				"rules": {
					"nursery": {},
					"performance": {
						"useTopLevelRegex": "off"
					},
					"style": {
						"noExcessiveLinesPerFile": "off"
					}
				}
			}
		},

		{
			"includes": ["tests/fixtures/**/*"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off"
					},
					"style": {
						"useImportType": "off"
					}
				}
			}
		},

		{
			"includes": ["*.config.{ts,mjs}"],
			"linter": {
				"rules": {
					"style": {
						"noProcessEnv": "off"
					}
				}
			}
		},

		{
			"assist": {
				"actions": {
					"source": {
						"useSortedAttributes": "off"
					}
				}
			},
			"includes": [
				"documentation/src/components/badge.astro",
				"documentation/src/components/icon.astro",
				"documentation/src/components/rule-example.astro"
			]
		},

		{
			"includes": ["documentation/src/components/rule-options.astro"],
			"linter": {
				"rules": {
					"performance": {
						"useSolidForComponent": "off"
					},
					"style": {
						"noJsxLiterals": "off"
					}
				}
			}
		},

		{
			"includes": ["documentation/src/types/satteri-optional-peers.d.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUndeclaredDependencies": "off"
					}
				}
			}
		},

		{
			"includes": ["**/*.d.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off"
					},
					"style": {
						"noNamespace": "off"
					}
				}
			}
		},

		{
			"includes": ["tests/fixtures/strict-boundaries/basic-app/app/components/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"useFilenamingConvention": "off"
					}
				}
			}
		}

		// package.json exception
		// {
		// 	"assist": {
		// 		"actions": {
		// 			"source": {
		// 				"useSortedKeys": "off",
		// 				"useSortedPackageJson": "on"
		// 			}
		// 		}
		// 	},
		// 	"formatter": { "enabled": false },
		// 	"includes": ["package.json"]
		// }
	],

	"vcs": {
		"clientKind": "git",
		"defaultBranch": "main",
		"enabled": true,
		"useIgnoreFile": true
	}
}
