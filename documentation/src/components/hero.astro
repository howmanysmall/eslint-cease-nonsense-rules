---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import { LinkButton } from "@astrojs/starlight/components";
import DraftContentNotice from "virtual:starlight/components/DraftContentNotice";

// Bindings so static analysis treats template component usage as live.
const HeroDraftNotice = DraftContentNotice;
const HeroImage = Image;
const HeroLinkButton = LinkButton;

const PAGE_TITLE_ID = "_top";

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, image, actions = [] } = data.hero || {};

const imageAttributes = {
	alt: image?.alt || "",
	decoding: "async" as const,
	height: 400,
	loading: "eager" as const,
	width: 400,
};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
let rawHtml: string | undefined;

if (image) {
	if ("file" in image) {
		darkImage = image.file;
	} else if ("dark" in image) {
		darkImage = image.dark;
		lightImage = image.light;
	} else {
		rawHtml = image.html;
	}
}

const showLintTicket = data.template === "splash";
---

<div class:list={["hero", showLintTicket && "hero--with-ticket"]}>
	{
		darkImage && (
			<HeroImage
				src={darkImage}
				{...imageAttributes}
				class:list={{ "light:sl-hidden": Boolean(lightImage) }}
			/>
		)
	}
	{lightImage && <HeroImage src={lightImage} {...imageAttributes} class="dark:sl-hidden" />}
	{rawHtml && <div class="hero-html sl-flex" set:html={rawHtml} />}

	<div class="sl-flex stack">
		<div class="sl-flex copy">
			<h1 id={PAGE_TITLE_ID} data-page-title set:html={title} />
			{data.draft && <HeroDraftNotice />}
			{tagline && <div class="tagline" set:html={tagline} />}
		</div>

		{
			actions.length > 0 && (
				<div class="sl-flex actions">
					{actions.map(
						({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant }) => (
							<HeroLinkButton href={href} variant={variant} icon={icon?.name} class:list={[className]} {...attrs}>
								{text}
								{icon?.html && <Fragment set:html={icon.html} />}
							</HeroLinkButton>
						),
					)}
				</div>
			)
		}

		{
			showLintTicket && (
				<aside class="lint-ticket" aria-label="Example lint failure and fix">
					<header class="lint-ticket__chrome">
						<span class="lint-ticket__dots" aria-hidden="true">
							<span />
							<span />
							<span />
						</span>
						<span class="lint-ticket__title">
							<span class="lint-ticket__plugin">cease-nonsense</span>
							<span class="lint-ticket__sep">·</span>
							<code class="lint-ticket__rule">no-print</code>
						</span>
					</header>
					<div class="lint-ticket__body">
						<div class="lint-ticket__pane lint-ticket__pane--fail">
							<div class="lint-ticket__label">Incorrect</div>
							<pre class="lint-ticket__code"><code>print("request failed")</code></pre>
							<div class="lint-ticket__message">error  no-print</div>
						</div>
						<div class="lint-ticket__pane lint-ticket__pane--pass">
							<div class="lint-ticket__label">Correct</div>
							<pre class="lint-ticket__code"><code>logger.error("request failed")</code></pre>
							<div class="lint-ticket__message">clean</div>
						</div>
					</div>
				</aside>
			)
		}
	</div>
</div>

<style>
	@layer starlight.core {
		.hero {
			display: grid;
			grid-template-columns: 100%;
			gap: 1.25rem;
			align-items: center;
			/* Keep splash hero tight — Starlight default can add ~10rem vertical air */
			padding-block: 0.5rem 1.25rem;
		}

		.hero > img,
		.hero > .hero-html {
			object-fit: contain;
			width: min(55%, 14rem);
			height: auto;
			margin-inline: auto;
		}

		.stack {
			flex-direction: column;
			gap: 1rem;
			text-align: center;
		}

		.copy {
			flex-direction: column;
			gap: 0.65rem;
			align-items: center;
		}

		.copy > * {
			max-width: 50ch;
		}

		h1 {
			margin: 0;
			font-size: clamp(var(--sl-text-3xl), calc(0.25rem + 5vw), var(--sl-text-6xl));
			line-height: var(--sl-line-height-headings);
			font-weight: 600;
			color: var(--sl-color-white);
		}

		.tagline {
			margin: 0;
			font-size: clamp(var(--sl-text-base), calc(0.0625rem + 2vw), var(--sl-text-xl));
			color: var(--sl-color-gray-2);
		}

		.actions {
			gap: 0.75rem 1.5rem;
			flex-wrap: wrap;
			justify-content: center;
		}

		@media (min-width: 50rem) {
			.hero {
				grid-template-columns: 7fr 4fr;
				gap: 2rem 3%;
				align-items: center;
				padding-block: 1.25rem 1.75rem;
			}

			.hero > img,
			.hero > .hero-html {
				order: 2;
				width: min(100%, 15rem);
			}

			.stack {
				gap: 1.1rem;
				text-align: start;
			}

			.copy,
			.actions {
				align-items: flex-start;
				justify-content: flex-start;
			}
		}
	}
</style>
