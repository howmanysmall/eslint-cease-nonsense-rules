---
export interface Props {
	title?: string;
	type: "pass" | "fail";
}

const { type, title } = Astro.props;

const isPass = type === "pass";
const icon = isPass
	? `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="RuleExample-icon"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`
	: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="RuleExample-icon"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;

const statusText = isPass ? "Correct" : "Incorrect";
const displayTitle = title ?? statusText;
---

<div class={`RuleExample RuleExample--${type}`}>
	<div class="RuleExample-header">
		<span class="RuleExample-status" set:html={icon} />
		<span class="RuleExample-title">{displayTitle}</span>
	</div>
	<div class="RuleExample-content">
		<slot />
	</div>
</div>
